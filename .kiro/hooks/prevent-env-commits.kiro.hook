{
  "enabled": true,
  "name": "Prevent .env Commits",
  "description": "Warn if .env files are modified (should never be committed)",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/.env",
      "**/.env.local"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "🚨 STOP. You're editing a .env file. These contain secrets and should NEVER be committed. Check .gitignore is working."
  }
}