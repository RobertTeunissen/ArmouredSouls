{
  "name": "armoured-souls-backend",
  "version": "0.1.0",
  "description": "Backend for Armoured Souls Phase 1 Prototype",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc --project tsconfig.seed.json && cp -r src/content dist/content",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "test": "jest --config jest.config.unit.js --forceExit; jest --config jest.config.integration.js --forceExit",
    "test:unit": "jest --config jest.config.unit.js --forceExit",
    "test:integration": "jest --config jest.config.integration.js --forceExit",
    "test:heavy": "jest --config jest.config.heavy.js --forceExit",
    "test:all": "npm run test && npm run test:heavy",
    "test:matchmaking": "tsx scripts/testMatchmaking.ts",
    "test:robot-stats": "tsx scripts/testRobotStats.ts"
  },
  "keywords": [
    "game",
    "battle",
    "robot"
  ],
  "author": "Robert Teunissen",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "overrides": {
    "express": "^5.1.0",
    "prisma": "^7.0.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.0.0",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.1",
    "gray-matter": "^4.0.3",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.39.4",
    "eslint-plugin-security": "^4.0.0",
    "fast-check": "^4.6.0",
    "globals": "^17.4.0",
    "jest": "^30.0.0",
    "prisma": "^7.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.57.1"
  }
}
