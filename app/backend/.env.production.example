# Armoured Souls — Production Environment Configuration
# Copy this file to .env and fill in the values

# Application
NODE_ENV=production
PORT=3001

# Database (PostgreSQL via Docker)
DATABASE_URL=postgresql://as_prd:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:5432/armouredsouls_prd?connection_limit=10

# Authentication
# REQUIRED: Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# CORS — comma-separated allowed origins
CORS_ORIGIN=https://armouredsouls.com,https://www.armouredsouls.com

# Scheduler
SCHEDULER_ENABLED=true
LEAGUE_SCHEDULE=0 8 * * *
TOURNAMENT_SCHEDULE=0 10 * * *
TAGTEAM_SCHEDULE=0 11 * * *
KOTH_SCHEDULE=0 13 * * *
SETTLEMENT_SCHEDULE=0 0 * * *
# Reserved slots for future battle modes
TEAM_2V2_LEAGUE_SCHEDULE=0 9 * * *
TEAM_3V3_LEAGUE_SCHEDULE=0 14 * * *
TEAM_2V2_TOURNAMENT_SCHEDULE=0 15 * * *
TEAM_3V3_TOURNAMENT_SCHEDULE=0 18 * * *
GRAND_MELEE_SCHEDULE=0 17 * * *

# Logging
LOG_LEVEL=info

# Deploy token for CI/CD changelog generation
# Generate with: openssl rand -hex 32
CHANGELOG_DEPLOY_TOKEN=CHANGE_ME_GENERATE_WITH_OPENSSL

# Docker PostgreSQL credentials (used by docker-compose.production.yml)
POSTGRES_USER=as_prd
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=armouredsouls_prd

# Monitoring & Alerting
# Discord webhook for ops alerts (disk, startup, backup, deploy failures).
# Falls back to DISCORD_WEBHOOK_URL if not set.
# MONITORING_DISCORD_WEBHOOK=https://discord.com/api/webhooks/CHANGE_ME
# Cron schedule for daily health report (default: 00:30 UTC, post-settlement)
# DAILY_REPORT_SCHEDULE=30 0 * * *
